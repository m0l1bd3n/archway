{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": [
      "@ragempcommunity/types-client",
      "@ragempcommunity/types-server",
      "@ragempcommunity/types-cef"
    ]
  },
  "include": ["./"]
}
